{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tabview.local/schemas/theme.schema.json",
  "title": "Tabview Theme",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["auto", "ansi16", "ansi256", "hex32", "truecolor"],
      "default": "auto"
    },
    "palette": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/color"
      }
    },
    "identifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "colors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/color"
          },
          "description": "Theme-level identifier color families. Each family generates 16 dark-to-light shades."
        }
      }
    },
    "styles": {
      "$ref": "#/$defs/styleTree",
      "description": "Nested YAML style tokens such as styles.table.cell, styles.popup.border, and styles.search.highlight."
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "minLength": 1,
      "description": "A 16-color name, palette(N), 0-255 palette index, #RRGGBB or #RRGGBBAA hex color, or palette alias."
    },
    "styleTree": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "$ref": "#/$defs/styleTree"
          },
          {
            "$ref": "#/$defs/style"
          }
        ]
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "$ref": "#/$defs/styleTree"
          },
          {
            "$ref": "#/$defs/style"
          }
        ]
      },
      "properties": {
        "fg": {
          "$ref": "#/$defs/color"
        },
        "bg": {
          "$ref": "#/$defs/color"
        },
        "modifiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["bold", "italic", "underline", "reversed", "dim"]
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tabview.local/schemas/view.schema.json",
  "title": "Tabview Saved View",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "filenames"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable saved view label. The canonical view name is the file stem."
    },
    "locale": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*(?:_[A-Za-z0-9]+)*(?:\\.[A-Za-z0-9_-]+)?(?:@[A-Za-z0-9_-]+)?$",
      "minLength": 1,
      "description": "Optional POSIX-style view-level locale identifier for locale-aware number formatting."
    },
    "filenames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "format": {
      "type": "string",
      "enum": ["auto", "delimited", "json", "ndjson"],
      "description": "Source format selected before the table is opened."
    },
    "json_path": {
      "type": "string",
      "pattern": "^(?:/(?:[^~]|~[01])*)*$",
      "description": "RFC 6901 JSON Pointer selecting the table node."
    },
    "schema_scan": {
      "type": "string",
      "enum": ["default", "full"]
    },
    "nulls": {
      "$ref": "#/$defs/nullPlacement"
    },
    "columns": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/column"
      }
    },
    "sort": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/sort"
      }
    },
    "filters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/filter"
      }
    }
  },
  "$defs": {
    "column": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "nulls": {
          "$ref": "#/$defs/nullPlacement"
        },
        "type": {
          "$ref": "#/$defs/columnType"
        },
        "format": {
          "$ref": "#/$defs/format"
        },
        "mask": {
          "type": "string",
          "pattern": "^(#,##)?0(\\.0+)?$"
        },
        "width": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "enum": ["header", "content", "mode", "max"]
            }
          ]
        },
        "align": {
          "type": "string",
          "enum": ["left", "right"]
        },
        "visible": {
          "type": "boolean",
          "default": true
        },
        "colors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/colorRule"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "format": {
                "const": "mask"
              }
            },
            "required": ["format"]
          },
          "then": {
            "required": ["mask"]
          }
        }
      ]
    },
    "colorRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gradient": {
          "$ref": "#/$defs/gradientColorRule"
        },
        "match": {
          "$ref": "#/$defs/matchColorRule"
        },
        "range": {
          "$ref": "#/$defs/rangeColorRule"
        },
        "identifiers": {
          "$ref": "#/$defs/identifiersColorRule"
        }
      },
      "oneOf": [
        {
          "required": ["gradient"]
        },
        {
          "required": ["match"]
        },
        {
          "required": ["range"]
        },
        {
          "required": ["identifiers"]
        }
      ]
    },
    "colorValue": {
      "type": "string",
      "minLength": 1,
      "description": "A theme palette alias, 16-color name, palette(N) 256-color value, integer 256-color value, or #RRGGBB/#RRGGBBAA hex color."
    },
    "gradientColorRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["auto", "fixed"]
        },
        "steps": {
          "type": "integer",
          "minimum": 1,
          "default": 8
        },
        "colors": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/colorValue"
          }
        },
        "stops": {
          "type": "object",
          "minProperties": 2,
          "propertyNames": {
            "pattern": "^-?(?:[0-9]+(?:\\.[0-9]+)?|\\.[0-9]+)$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/colorValue"
          },
          "description": "Map of inclusive numeric stop values to colors, for example 0: green, 100: yellow, 500: red."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "auto"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["colors"]
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "fixed"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["stops"]
          }
        }
      ]
    },
    "matchColorRule": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/colorValue"
      },
      "description": "Map of exact discrete values to colors, for example true: green, 0: yellow, or p: darkgreen."
    },
    "rangeColorRule": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/colorValue"
      },
      "description": "Map of numeric comparison expressions to colors, for example \"<10\": red, \">=90\": red, or \">=50 <75\": yellow."
    },
    "identifiersColorRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "colors": {
          "oneOf": [
            {
              "type": "string",
              "const": "auto"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/colorValue"
              }
            }
          ],
          "default": "auto"
        }
      },
      "description": "String-mode coloring that assigns each unique rendered column value to generated colors from theme-level or view-level color families."
    },
    "columnType": {
      "type": "string",
      "enum": [
        "string",
        "text",
        "date",
        "number",
        "float",
        "integer",
        "semver",
        "ip",
        "boolean",
        "char",
        "bit",
        "word"
      ]
    },
    "nullPlacement": {
      "type": "string",
      "enum": ["first", "last"]
    },
    "format": {
      "type": "string",
      "enum": [
        "plain",
        "locale",
        "mask",
        "uppercase",
        "lowercase",
        "char",
        "bit",
        "word"
      ]
    },
    "sort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["column", "direction", "kind"],
      "properties": {
        "column": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"]
        },
        "kind": {
          "type": "string",
          "enum": ["lexical", "natural", "numeric", "type"]
        }
      }
    },
    "filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["column", "action", "kind", "condition"],
      "properties": {
        "column": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": ["in", "out"]
        },
        "kind": {
          "type": "string",
          "enum": ["text", "regex", "numeric"]
        },
        "condition": {
          "type": "string"
        }
      }
    }
  }
}
